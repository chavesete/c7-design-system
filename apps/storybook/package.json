{
  "name": "@chavesete/storybook",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "HOME=/tmp STORYBOOK_DISABLE_TELEMETRY=1 storybook dev -p 6006 --no-open",
    "dev:docker": "HOME=/tmp STORYBOOK_DISABLE_TELEMETRY=1 storybook dev -p 6006 --no-open --host 0.0.0.0",
    "build": "pnpm -r --filter @chavesete/tokens --filter @chavesete/tailwind-preset --filter @chavesete/ui build && HOME=/tmp STORYBOOK_DISABLE_TELEMETRY=1 storybook build -o storybook-static",
    "start": "tsx server.ts",
    "mcp:docs": "tsx server.ts"
  },
  "dependencies": {
    "@chavesete/tailwind-preset": "workspace:*",
    "@chavesete/tokens": "workspace:*",
    "@chavesete/ui": "workspace:*",
    "@fontsource/metropolis": "^5.2.5",
    "@radix-ui/react-popover": "^1.1.2",
    "@radix-ui/react-slider": "^1.2.1",
    "date-fns": "^3.6.0",
    "lucide-react": "^0.460.0",
    "react": "18.2.0",
    "react-day-picker": "^8.10.1",
    "react-dom": "18.2.0"
  },
  "devDependencies": {
    "@storybook/addon-docs": "^10.3.5",
    "@storybook/addon-mcp": "^0.6.0",
    "@storybook/mcp": "^0.7.0",
    "@storybook/react-vite": "^10.3.5",
    "@types/node": "^22.16.5",
    "@vitejs/plugin-react": "^6.0.1",
    "autoprefixer": "^10.4.21",
    "postcss": "^8.5.6",
    "storybook": "^10.3.5",
    "tailwindcss": "^3.4.17",
    "tsx": "^4.21.0",
    "vite": "^8.0.10"
  }
}
