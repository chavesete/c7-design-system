{
  "name": "@chavesete/tailwind-preset",
  "version": "0.0.1",
  "sideEffects": false,
  "publishConfig": {
    "access": "public"
  },
  "peerDependencies": {
    "tailwindcss": ">=3.3.0"
  },
  "dependencies": {
    "@chavesete/tokens": "workspace:*"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup src/index.ts --format esm,cjs --dts"
  }
}
