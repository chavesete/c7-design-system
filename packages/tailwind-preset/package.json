{
  "name": "@chavesete/tailwind-preset",
  "version": "0.0.4",
  "sideEffects": false,
  "publishConfig": {
    "access": "public"
  },
  "peerDependencies": {
    "tailwindcss": ">=3.3.0"
  },
  "dependencies": {
    "@chavesete/tokens": "workspace:*"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    },
    "./v4.css": "./dist/v4.css"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup src/index.ts --format esm,cjs --dts && node -e \"require('node:fs').cpSync('src/v4.css','dist/v4.css',{force:true})\""
  }
}
