{
  "name": "@chavesete/tokens",
  "version": "0.0.0",
  "sideEffects": false,
  "publishConfig": {
    "access": "public"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    },
    "./styles.css": "./dist/styles.css"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup src/index.ts --format esm,cjs --dts && node -e \"require('node:fs').cpSync('src/styles.css','dist/styles.css',{force:true})\""
  }
}
