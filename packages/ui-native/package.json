{
  "name": "@chavesete/ui-native",
  "version": "0.0.0",
  "sideEffects": false,
  "publishConfig": {
    "access": "public"
  },
  "peerDependencies": {
    "react": ">=18",
    "react-native": ">=0.72",
    "react-native-svg": ">=13"
  },
  "dependencies": {
    "@chavesete/tokens": "workspace:*",
    "@chavesete/tailwind-preset": "workspace:*"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup src/index.ts --format esm,cjs --dts"
  }
}
