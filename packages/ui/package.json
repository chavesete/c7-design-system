{
  "name": "@chavesete/ui",
  "version": "0.0.0",
  "sideEffects": false,
  "publishConfig": {
    "access": "public"
  },
  "peerDependencies": {
    "react": ">=18",
    "react-dom": ">=18"
  },
  "dependencies": {
    "@chavesete/tokens": "workspace:*",
    "@chavesete/tailwind-preset": "workspace:*",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "tailwind-merge": "^2.6.0"
  },
  "exports": {
    ".": {
